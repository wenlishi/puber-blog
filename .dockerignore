# =====================================================
# Docker构建忽略文件
# =====================================================
# 排除不需要复制到镜像的文件，加速构建
# =====================================================

# Git相关
.git
.gitignore

# IDE配置
.idea
.vscode
*.iml

# 构建输出（保留jar包，排除其他target内容）
target/
!target/*.jar

# 日志文件
logs/
*.log

# 临时文件
*.tmp
*.swp
*.bak

# 系统文件
.DS_Store
Thumbs.db

# 文档（不需要在生产镜像）
学习资料/
*.md
!README.md

# Docker相关文件（不需要递归）
Dockerfile
docker-compose.yml
.dockerignore

# 环境配置文件（敏感信息）
.env
.env.local

# Node.js相关（如果有前端构建）
node_modules/
npm-debug.log

# 测试文件
src/test/