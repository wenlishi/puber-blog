# =====================================================
# Docker Compose环境变量配置示例
# =====================================================
# 复制此文件为.env并修改配置
# =====================================================

# 数据库密码（必须修改）
DB_PASSWORD=your_secure_password_here

# JVM参数（可选，默认值已优化）
JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC -Djava.security.egd=file:/dev/./urandom

# Spring Profile（可选）
SPRING_PROFILES_ACTIVE=prod

# 文件上传路径（可选，默认容器内路径）
FILE_UPLOAD_PATH=/app/uploads